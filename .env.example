APP_ENV=development
SERVER_PORT=8080
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rota
POSTGRES_PASSWORD=
POSTGRES_DB=rota
SESSION_EXPIRES_HOURS=336

EMAIL_MODE=log
# In production, set SMTP_* to real provider credentials and do not commit them.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Rota <noreply@example.com>
# SMTP_TLS_MODE controls how SMTP connections are secured.
# starttls is the secure default, implicit is for SMTPS/465, and none is only for local unauthenticated relays.
# Existing SMTP setups that relied on opportunistic STARTTLS must move to implicit or explicitly opt into none for local-only relays.
SMTP_TLS_MODE=starttls
EMAIL_SEND_TIMEOUT=30s
# For local Docker deployment use http://localhost. For frontend dev with Vite, use http://localhost:5173.
CADDY_SITE_ADDRESS=http://localhost
# APP_BASE_URL must match the public URL served by Caddy in production, for example http://localhost or https://rota.example.com.
APP_BASE_URL=http://localhost:5173
INVITATION_TOKEN_TTL=72h
PASSWORD_RESET_TOKEN_TTL=1h

# Required only when there is no admin user in the database.
# Set BOOTSTRAP_ADMIN_PASSWORD before production deploy and do not commit the real value.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Administrator
