{{define "content"}}
<p style="margin:0 0 16px 0;">Hi {{.Name}},</p>
<p style="margin:0 0 18px 0;">An email-change request was made for your {{.ProductName}} account.</p>
<p style="margin:0 0 18px 0;">Requested new address: <strong>{{.NewEmailPartial}}</strong></p>
<p style="margin:0;color:#4b5563;">If this was not you, change your password immediately and contact an administrator.</p>
{{end}}
