{{define "content"}}
<p style="margin:0 0 16px 0;">{{.Name}}，你好：</p>
{{if .HasOrganizationName}}<p style="margin:0 0 18px 0;">{{.OrganizationName}} 的管理员已邀请你加入 {{.ProductName}}。请设置密码来完成账号启用。</p>{{else}}<p style="margin:0 0 18px 0;">管理员已邀请你加入 {{.ProductName}}。请设置密码来完成账号启用。</p>{{end}}
<p style="margin:0 0 22px 0;"><a href="{{.ActionURL}}" style="display:inline-block;background:#111827;color:#ffffff;text-decoration:none;border-radius:6px;padding:10px 16px;font-weight:600;">{{.CTALabel}}</a></p>
<p style="margin:0 0 8px 0;color:#4b5563;">{{.FallbackLabel}}</p>
<p style="margin:0 0 18px 0;word-break:break-all;"><a href="{{.ActionURL}}" style="color:#2563eb;">{{.ActionURL}}</a></p>
<p style="margin:0;color:#4b5563;">此链接将在 {{.ExpirationText}} 后过期。如果你没有预期收到邀请，可以忽略这封邮件。</p>
{{end}}
